; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="kw_Godot"
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/show_image=false
config/icon="res://icon.svg"

[autoload]

MobileOrientationGuardGlobal="*res://scripts/ui/mobile_orientation_guard_global.gd"
WebAudioUnlock="*res://scripts/audio/web_audio_unlock.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[kw]

auth_api_base_url="https://play.outrage.ink/auth"
default_server_host="wss://play.outrage.ink/ws"
default_server_port=443
enable_auth_direct_port_fallback=false
enable_network_mode_picker=false
network_transport="websocket"
network_ws_scheme="wss"

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
